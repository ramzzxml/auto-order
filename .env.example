# Database (Neon PostgreSQL) - use the "pooled" connection string from Neon
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Optional direct (non-pooled) connection, used by Prisma migrate
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Payment Gateway
PAYMENT_GATEWAY_BASE_URL="https://payqris.web.id"
PAYMENT_GATEWAY_API_KEY="your_api_key_here"

# Admin auth
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change_this_password"
ADMIN_JWT_SECRET="replace_with_a_long_random_string"

# Store
STORE_NAME="Auto Order Store"
NEXT_PUBLIC_STORE_NAME="Auto Order Store"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
